# Prophecy Templates — Environment Variables
#
# Copy this file to .env.local in each app (apps/00-minimal/.env.local etc.)
# and fill in the values you need.

# ============================================================
# Network selection — "staging" or "development"
# Controls which set of contract addresses the SDK uses.
# Default: staging (more stable for demos)
# ============================================================
NEXT_PUBLIC_PROPHECY_NETWORK=staging

# ============================================================
# Somnia testnet RPC
# Public RPC works for reads; for writes use a provider or the default.
# ============================================================
NEXT_PUBLIC_SOMNIA_RPC_URL=https://dream-rpc.somnia.network

# ============================================================
# Venue configuration
# Every market must belong to a venue. The default below points to the
# signerless "Hackathon Public Venue" deployed by Somnia DevRel on
# Somnia testnet staging. It takes the protocol default fees
# (300 bps trade / 100 bps settlement reward) and has no allow-list.
#
# If you want to run your own venue (own fees, gated access, etc.),
# run `npm run deploy:venue` with your own OPERATOR_PRIVATE_KEY and
# paste the resulting venueId here.
# ============================================================
NEXT_PUBLIC_PROPHECY_VENUE_ID=54

# ============================================================
# Optional — for scripts that need to sign transactions
# (create-market, resolve-market, deploy-venue).
# NEVER commit this. Use a disposable testnet wallet.
# ============================================================
OPERATOR_PRIVATE_KEY=
